# ============================================================
# COPY FILE NÀY THÀNH .env VÀ ĐIỀN GIÁ TRỊ THỰC
# cp .env.example .env
# ============================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
TELEGRAM_CHAT_ID=-1001234567890

# --- PMS API ---
PMS_BASE_URL=https://apis-stag.fpt.vn
PMS_AUTH_TOKEN=your_jwt_token_here

# --- GitHub ---
GITHUB_TOKEN=ghp_your_github_token

# --- Figma ---
FIGMA_ACCESS_TOKEN=figd_your_figma_token

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
# Vite (browser UI)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key

# --- Firebase ---
FIREBASE_PROJECT_ID=your_firebase_project_id
