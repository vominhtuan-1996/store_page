# --- Supabase ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_your_anon_key

# --- Groq (AI Agent) ---
VITE_GROQ_API_KEY=gsk_your_groq_api_key

# --- Telegram ---
VITE_TELEGRAM_BOT_TOKEN=123456:ABC-DEF_your_bot_token
VITE_TELEGRAM_CHAT_ID=-1001234567890
